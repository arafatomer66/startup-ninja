# Fastlane lanes for Startup Ninja Android releases.
#
# All lanes assume:
#   - Flutter is on PATH (run `flutter doctor` if not)
#   - android/key.properties + the keystore at /Users/mdomerarafat/startupninja.jks
#     are present (already configured in build.gradle.kts)
#   - android/fastlane/play-store-service-account.json exists (gitignored)
#
# Track naming note: this app ships to **Closed testing**. In Play Console
# API terms that's the `alpha` track (legacy name). All lanes target alpha.
#
# Common usage:
#   cd android && fastlane closed              # build + upload to Closed testing as draft
#   cd android && fastlane closed_rollout      # build + upload + roll out to Closed testing
#   cd android && fastlane closed_dryrun       # validate everything without uploading
#   cd android && fastlane promote_closed_to_open
#   cd android && fastlane promote_to_production

default_platform(:android)

# Bump only the build number (versionCode) — keep semver name untouched.
# Reads version: from pubspec.yaml, increments the +N suffix, writes it back.
def bump_pubspec_build_number
  pubspec = File.expand_path("../../pubspec.yaml", __dir__)
  content = File.read(pubspec)
  m = content.match(/^version:\s*(\d+\.\d+\.\d+)\+(\d+)\s*$/)
  raise "Could not parse version: line in pubspec.yaml" unless m
  name, code = m[1], m[2].to_i
  new_code = code + 1
  new_line = "version: #{name}+#{new_code}"
  File.write(pubspec, content.sub(/^version:.*$/, new_line))
  UI.success("Bumped pubspec.yaml: #{name}+#{code} → #{name}+#{new_code}")
  { name: name, code: new_code }
end

platform :android do
  desc "Build a fresh signed release App Bundle (.aab) via Flutter"
  lane :build_aab do
    sh("cd .. && flutter clean")
    sh("cd .. && flutter pub get")
    sh("cd .. && flutter build appbundle --release")
    aab = "../build/app/outputs/bundle/release/app-release.aab"
    UI.success("Built #{File.expand_path(aab)}")
    aab
  end

  desc "Build a fresh signed release APK (.apk) via Flutter — for Firebase App Distribution"
  lane :build_apk do
    sh("cd .. && flutter clean")
    sh("cd .. && flutter pub get")
    sh("cd .. && flutter build apk --release")
    apk = "../build/app/outputs/flutter-apk/app-release.apk"
    UI.success("Built #{File.expand_path(apk)}")
    apk
  end

  # ── Firebase App Distribution lanes ──────────────────────────────────────────
  # Reads FIREBASE_APP_ID + FIREBASE_TOKEN from env (or .env.firebase), uploads
  # the latest signed APK, notifies the testers group.

  desc "Bump versionCode, build APK, ship to Firebase App Distribution"
  lane :firebase do
    version = bump_pubspec_build_number
    build_apk
    notes = ENV["RELEASE_NOTES"] || "Build #{version[:name]}+#{version[:code]} from main"
    sh(%(
      cd .. && firebase appdistribution:distribute \
        build/app/outputs/flutter-apk/app-release.apk \
        --app "#{ENV['FIREBASE_APP_ID']}" \
        --release-notes "#{notes}" \
        --groups "testers"
    ).gsub(/\s+/, ' '))
    UI.success("#{version[:name]}+#{version[:code]} sent to Firebase App Distribution → testers group.")
  end

  desc "Validate Firebase CLI auth + App ID without uploading"
  lane :firebase_dryrun do
    if ENV["FIREBASE_APP_ID"].to_s.empty?
      UI.user_error!("FIREBASE_APP_ID is not set")
    end
    sh(%(firebase apps:list --project "#{ENV['FIREBASE_PROJECT_ID']}"))
    UI.success("Firebase auth + project access confirmed.")
  end

  desc "Bump versionCode, build, and upload to Closed testing as a draft"
  lane :closed do
    version = bump_pubspec_build_number
    build_aab
    upload_to_play_store(
      track: "alpha",
      aab: "../build/app/outputs/bundle/release/app-release.aab",
      release_status: "draft",
      skip_upload_metadata: true,
      skip_upload_changelogs: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
    )
    UI.success("Uploaded #{version[:name]}+#{version[:code]} to Closed testing as a draft. Open Play Console → Closed testing to roll it out.")
  end

  desc "Build + upload + immediately roll out to Closed testing (no draft step)"
  lane :closed_rollout do
    version = bump_pubspec_build_number
    build_aab
    upload_to_play_store(
      track: "alpha",
      aab: "../build/app/outputs/bundle/release/app-release.aab",
      release_status: "completed",
      skip_upload_metadata: true,
      skip_upload_changelogs: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
    )
    UI.success("#{version[:name]}+#{version[:code]} is live on Closed testing.")
  end

  desc "Validate fastlane + service account + Play Console connection without uploading"
  lane :closed_dryrun do
    upload_to_play_store(
      track: "alpha",
      validate_only: true,
      aab: "../build/app/outputs/bundle/release/app-release.aab",
      skip_upload_metadata: true,
      skip_upload_changelogs: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
    )
    UI.success("Dry-run OK — service account + Play Console wiring verified.")
  end

  desc "Promote the latest Closed testing build to the Open testing track"
  lane :promote_closed_to_open do
    upload_to_play_store(
      track: "alpha",
      track_promote_to: "beta",
      skip_upload_aab: true,
      skip_upload_apk: true,
      skip_upload_metadata: true,
      skip_upload_changelogs: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
    )
  end

  desc "Promote the latest Closed testing build to Production (10% staged rollout)"
  lane :promote_to_production do
    upload_to_play_store(
      track: "alpha",
      track_promote_to: "production",
      rollout: "0.1",
      skip_upload_aab: true,
      skip_upload_apk: true,
      skip_upload_metadata: true,
      skip_upload_changelogs: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
    )
  end
end
